# Drop this file (renamed to `.yamlls.yaml`) at the root of your repo.

schemas:
  "https://json.schemastore.org/github-workflow.json":
    - ".github/workflows/*.yml"
  "./schemas/local.json":
    - "k8s/**/*.yaml"

catalog: true
# catalogUrl: ""   # override the schemastore.org endpoint

# kubernetes.schemaUrl overrides the URL template used by apiVersion+kind
# auto-detect. Placeholders: {group}, {groupSeg}, {groupFirst}, {kind},
# {kindLower}, {version}, {versionLower}. Defaults to the yannh layout.
#
# kubernetes:
#   schemaUrl: "https://schemas.example.com/{groupSeg}{kindLower}_{versionLower}.json"

# Per-renderer config. Defaults shown — only set when overriding.
#
# renderers:
#   flate:
#     enabled: true
#     binary: flate
